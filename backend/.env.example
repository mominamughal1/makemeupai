APP_NAME=MakemeupAI
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Production (Railway): set APP_URL to your API host, FRONTEND_URL to Vercel URL.
# Cross-site Sanctum (Vercel SPA + Railway API) requires:
#   SESSION_SECURE_COOKIE=true
#   SESSION_SAME_SITE=none
#   SESSION_DOMAIN=          (leave empty)
#   SANCTUM_STATEFUL_DOMAINS=makemeupai.vercel.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite
DB_FOREIGN_KEYS=true

# Production (Railway PostgreSQL):
# DB_CONNECTION=pgsql
# DB_URL=${DATABASE_URL}   (Railway injects DATABASE_URL automatically)

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

# Production cross-site cookies (see FRONTEND_URL note above):
# SESSION_DOMAIN=
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=none

SANCTUM_STATEFUL_DOMAINS=localhost:5173

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@makemeupai.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Optional: set for live weather in recommendations API (fallback used when empty)
OPENWEATHER_KEY=
